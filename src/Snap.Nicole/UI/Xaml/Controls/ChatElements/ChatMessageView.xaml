<UserControl
    x:Class="Snap.Nicole.UI.Xaml.Controls.ChatElements.ChatMessageView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:snuxcc="using:Snap.Nicole.UI.Xaml.Controls.ChatElements"
    xmlns:snuxm="using:Snap.Nicole.UI.Xaml.Markup"
    mc:Ignorable="d">

    <UserControl.Resources>
        <snuxcc:ReasoningContentTitleConverter x:Key="ReasoningContentTitleConverter" />
        <snuxcc:UsageCountVisibilityConverter x:Key="UsageCountVisibilityConverter" />

        <DataTemplate x:Key="TextContentTemplate">
            <snuxcc:ChatMarkdownSegmentView Markdown="{Binding Text}" />
        </DataTemplate>

        <DataTemplate x:Key="ReasoningContentTemplate">
            <Border
                Padding="8"
                Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="{ThemeResource ControlCornerRadius}">
                <snuxcc:ChatMarkdownSegmentView Title="{Binding IsCompleted, Converter={StaticResource ReasoningContentTitleConverter}}" Markdown="{Binding Text}" />
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="FunctionCallContentTemplate">
            <snuxcc:ChatFunctionCallSegmentView FunctionCall="{Binding}" />
        </DataTemplate>

        <DataTemplate x:Key="FunctionResultContentTemplate">
            <snuxcc:ChatFunctionResultSegmentView FunctionResult="{Binding}" />
        </DataTemplate>

        <DataTemplate x:Key="UsageContentTemplate">
            <StackPanel Spacing="2">
                <TextBlock
                    FontSize="12"
                    FontWeight="SemiBold"
                    Opacity="0.7"
                    Text="{snuxm:StringResource Name=UIXamlControlsChatMessageViewLabelUsage}" />

                <Grid ColumnSpacing="12" RowSpacing="6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel
                        Grid.Row="0"
                        Grid.Column="0"
                        Orientation="Horizontal"
                        Spacing="4"
                        ToolTipService.ToolTip="Total"
                        Visibility="{Binding TotalTokenCount, Converter={StaticResource UsageCountVisibilityConverter}}">
                        <SymbolIcon Symbol="Calculator" />
                        <TextBlock
                            FontFamily="Cascadia Code, Consolas, Courier New"
                            FontSize="14"
                            FontWeight="SemiBold"
                            IsTextSelectionEnabled="True"
                            Text="{Binding TotalTokenCount}" />
                    </StackPanel>

                    <StackPanel
                        Grid.Row="0"
                        Grid.Column="1"
                        Orientation="Horizontal"
                        Spacing="4"
                        ToolTipService.ToolTip="Input"
                        Visibility="{Binding InputTokenCount, Converter={StaticResource UsageCountVisibilityConverter}}">
                        <SymbolIcon Symbol="Download" />
                        <TextBlock
                            FontFamily="Cascadia Code, Consolas, Courier New"
                            FontSize="14"
                            FontWeight="SemiBold"
                            IsTextSelectionEnabled="True"
                            Text="{Binding InputTokenCount}" />
                    </StackPanel>

                    <StackPanel
                        Grid.Row="0"
                        Grid.Column="2"
                        Orientation="Horizontal"
                        Spacing="4"
                        ToolTipService.ToolTip="Output"
                        Visibility="{Binding OutputTokenCount, Converter={StaticResource UsageCountVisibilityConverter}}">
                        <SymbolIcon Symbol="Upload" />
                        <TextBlock
                            FontFamily="Cascadia Code, Consolas, Courier New"
                            FontSize="14"
                            FontWeight="SemiBold"
                            IsTextSelectionEnabled="True"
                            Text="{Binding OutputTokenCount}" />
                    </StackPanel>

                    <StackPanel
                        Grid.Row="1"
                        Grid.Column="0"
                        Orientation="Horizontal"
                        Spacing="4"
                        ToolTipService.ToolTip="Reasoning"
                        Visibility="{Binding ReasoningTokenCount, Converter={StaticResource UsageCountVisibilityConverter}}">
                        <SymbolIcon Symbol="Help" />
                        <TextBlock
                            FontFamily="Cascadia Code, Consolas, Courier New"
                            FontSize="14"
                            FontWeight="SemiBold"
                            IsTextSelectionEnabled="True"
                            Text="{Binding ReasoningTokenCount}" />
                    </StackPanel>

                    <StackPanel
                        Grid.Row="1"
                        Grid.Column="1"
                        Orientation="Horizontal"
                        Spacing="4"
                        ToolTipService.ToolTip="Cached Input"
                        Visibility="{Binding CachedInputTokenCount, Converter={StaticResource UsageCountVisibilityConverter}}">
                        <SymbolIcon Symbol="SaveLocal" />
                        <TextBlock
                            FontFamily="Cascadia Code, Consolas, Courier New"
                            FontSize="14"
                            FontWeight="SemiBold"
                            IsTextSelectionEnabled="True"
                            Text="{Binding CachedInputTokenCount}" />
                    </StackPanel>

                    <StackPanel
                        Grid.Row="1"
                        Grid.Column="2"
                        Orientation="Horizontal"
                        Spacing="4"
                        ToolTipService.ToolTip="Input Text"
                        Visibility="{Binding InputTextTokenCount, Converter={StaticResource UsageCountVisibilityConverter}}">
                        <SymbolIcon Symbol="Font" />
                        <TextBlock
                            FontFamily="Cascadia Code, Consolas, Courier New"
                            FontSize="14"
                            FontWeight="SemiBold"
                            IsTextSelectionEnabled="True"
                            Text="{Binding InputTextTokenCount}" />
                    </StackPanel>

                    <StackPanel
                        Grid.Row="2"
                        Grid.Column="0"
                        Orientation="Horizontal"
                        Spacing="4"
                        ToolTipService.ToolTip="Output Text"
                        Visibility="{Binding OutputTextTokenCount, Converter={StaticResource UsageCountVisibilityConverter}}">
                        <SymbolIcon Symbol="Document" />
                        <TextBlock
                            FontFamily="Cascadia Code, Consolas, Courier New"
                            FontSize="14"
                            FontWeight="SemiBold"
                            IsTextSelectionEnabled="True"
                            Text="{Binding OutputTextTokenCount}" />
                    </StackPanel>

                    <StackPanel
                        Grid.Row="2"
                        Grid.Column="1"
                        Orientation="Horizontal"
                        Spacing="4"
                        ToolTipService.ToolTip="Input Audio"
                        Visibility="{Binding InputAudioTokenCount, Converter={StaticResource UsageCountVisibilityConverter}}">
                        <SymbolIcon Symbol="Audio" />
                        <TextBlock
                            FontFamily="Cascadia Code, Consolas, Courier New"
                            FontSize="14"
                            FontWeight="SemiBold"
                            IsTextSelectionEnabled="True"
                            Text="{Binding InputAudioTokenCount}" />
                    </StackPanel>

                    <StackPanel
                        Grid.Row="2"
                        Grid.Column="2"
                        Orientation="Horizontal"
                        Spacing="4"
                        ToolTipService.ToolTip="Output Audio"
                        Visibility="{Binding OutputAudioTokenCount, Converter={StaticResource UsageCountVisibilityConverter}}">
                        <SymbolIcon Symbol="Volume" />
                        <TextBlock
                            FontFamily="Cascadia Code, Consolas, Courier New"
                            FontSize="14"
                            FontWeight="SemiBold"
                            IsTextSelectionEnabled="True"
                            Text="{Binding OutputAudioTokenCount}" />
                    </StackPanel>
                </Grid>
            </StackPanel>
        </DataTemplate>

        <DataTemplate x:Key="FallbackContentTemplate">
            <snuxcc:ChatObjectSegmentView Value="{Binding}" />
        </DataTemplate>

        <snuxcc:ChatContentTemplateSelector
            x:Key="ChatContentTemplateSelector"
            FallbackTemplate="{StaticResource FallbackContentTemplate}"
            FunctionCallTemplate="{StaticResource FunctionCallContentTemplate}"
            FunctionResultTemplate="{StaticResource FunctionResultContentTemplate}"
            ReasoningTemplate="{StaticResource ReasoningContentTemplate}"
            TextTemplate="{StaticResource TextContentTemplate}"
            UsageTemplate="{StaticResource UsageContentTemplate}" />
    </UserControl.Resources>

    <Border
        x:Name="MessageBorder"
        Padding="8"
        HorizontalAlignment="Stretch"
        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
        BorderThickness="1"
        CornerRadius="{ThemeResource ControlCornerRadius}">
        <StackPanel HorizontalAlignment="Stretch" Spacing="4">
            <TextBlock
                x:Name="HeaderTextBlock"
                FontSize="12"
                FontWeight="SemiBold"
                Opacity="0.7" />

            <TextBlock
                x:Name="UserMessageTextBlock"
                FontSize="14"
                IsTextSelectionEnabled="True"
                TextWrapping="Wrap" />

            <ItemsControl x:Name="ContentItemsControl" ItemTemplateSelector="{StaticResource ChatContentTemplateSelector}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Spacing="4" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>
        </StackPanel>
    </Border>
</UserControl>
