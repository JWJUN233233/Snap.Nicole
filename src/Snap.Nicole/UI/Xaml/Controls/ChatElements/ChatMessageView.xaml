<UserControl
    x:Class="Snap.Nicole.UI.Xaml.Controls.ChatElements.ChatMessageView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:cvt="using:CommunityToolkit.WinUI.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:snuxcc="using:Snap.Nicole.UI.Xaml.Controls.ChatElements"
    xmlns:snuxd="using:Snap.Nicole.UI.Xaml.Data"
    xmlns:snuxm="using:Snap.Nicole.UI.Xaml.Markup"
    mc:Ignorable="d">

    <UserControl.Resources>
        <cvt:BoolToObjectConverter
            x:Key="ReasoningContentTitleConverter"
            FalseValue="{snuxm:StringResource Name=UIXamlControlsChatMessageViewLabelReasoningInProgress}"
            TrueValue="{snuxm:StringResource Name=UIXamlControlsChatMessageViewLabelReasoningCompleted}" />
        <cvt:IFormattableToStringConverter x:Key="UsageCacheHitRateTextConverter" />
        <snuxd:EmptyObjectToVisibilityConverter x:Key="UsageCountVisibilityConverter" />

        <DataTemplate x:Key="TextContentTemplate">
            <snuxcc:ChatMarkdownSegmentView Markdown="{Binding Text}" />
        </DataTemplate>

        <DataTemplate x:Key="ReasoningContentTemplate">
            <Border
                Padding="8"
                Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="{ThemeResource ControlCornerRadius}">
                <snuxcc:ChatMarkdownSegmentView Title="{Binding IsCompleted, Converter={StaticResource ReasoningContentTitleConverter}}" Markdown="{Binding Text}" />
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="FunctionCallContentTemplate">
            <snuxcc:ChatFunctionCallSegmentView FunctionCall="{Binding}" />
        </DataTemplate>

        <DataTemplate x:Key="FunctionResultContentTemplate">
            <snuxcc:ChatFunctionResultSegmentView FunctionResult="{Binding}" />
        </DataTemplate>

        <DataTemplate x:Key="UsageContentTemplate">
            <StackPanel
                Opacity="0.7"
                Orientation="Horizontal"
                Spacing="6">

                <StackPanel
                    Orientation="Horizontal"
                    Spacing="4"
                    ToolTipService.ToolTip="{snuxm:StringResource Name=UIXamlControlsChatMessageViewToolTipTotalTokenCount}"
                    Visibility="{Binding TotalTokenCount, Converter={StaticResource UsageCountVisibilityConverter}}">
                    <FontIcon FontSize="14" Glyph="&#xE8A9;" />
                    <TextBlock
                        VerticalAlignment="Center"
                        Style="{ThemeResource CaptionTextBlockStyle}"
                        Text="{Binding TotalTokenCount}" />
                </StackPanel>

                <StackPanel
                    Orientation="Horizontal"
                    Spacing="4"
                    ToolTipService.ToolTip="{snuxm:StringResource Name=UIXamlControlsChatMessageViewToolTipInputTokenCount}"
                    Visibility="{Binding InputTokenCount, Converter={StaticResource UsageCountVisibilityConverter}}">
                    <FontIcon FontSize="14" Glyph="&#xE70E;" />
                    <TextBlock
                        VerticalAlignment="Center"
                        Style="{ThemeResource CaptionTextBlockStyle}"
                        Text="{Binding InputTokenCount}" />
                </StackPanel>

                <StackPanel
                    Grid.Column="2"
                    Orientation="Horizontal"
                    Spacing="4"
                    ToolTipService.ToolTip="{snuxm:StringResource Name=UIXamlControlsChatMessageViewToolTipOutputTokenCount}"
                    Visibility="{Binding OutputTokenCount, Converter={StaticResource UsageCountVisibilityConverter}}">
                    <FontIcon FontSize="14" Glyph="&#xE70D;" />
                    <TextBlock
                        VerticalAlignment="Center"
                        Style="{ThemeResource CaptionTextBlockStyle}"
                        Text="{Binding OutputTokenCount}" />
                </StackPanel>

                <StackPanel
                    Orientation="Horizontal"
                    Spacing="4"
                    ToolTipService.ToolTip="{snuxm:StringResource Name=UIXamlControlsChatMessageViewToolTipReasoningTokenCount}"
                    Visibility="{Binding ReasoningTokenCount, Converter={StaticResource UsageCountVisibilityConverter}}">
                    <FontIcon FontSize="14" Glyph="&#xE794;" />
                    <TextBlock
                        VerticalAlignment="Center"
                        Style="{ThemeResource CaptionTextBlockStyle}"
                        Text="{Binding ReasoningTokenCount}" />
                </StackPanel>

                <StackPanel
                    Grid.Column="4"
                    Orientation="Horizontal"
                    Spacing="4"
                    ToolTipService.ToolTip="{snuxm:StringResource Name=UIXamlControlsChatMessageViewToolTipCachedInputTokenCount}"
                    Visibility="{Binding CachedInputTokenCount, Converter={StaticResource UsageCountVisibilityConverter}}">
                    <FontIcon FontSize="14" Glyph="&#xE950;" />
                    <TextBlock
                        VerticalAlignment="Center"
                        Style="{ThemeResource CaptionTextBlockStyle}"
                        Text="{Binding CachedInputTokenCount}" />
                    <TextBlock
                        VerticalAlignment="Center"
                        Style="{ThemeResource CaptionTextBlockStyle}"
                        Text="{Binding CacheHitRate, Converter={StaticResource UsageCacheHitRateTextConverter}, ConverterParameter=P0}"
                        Visibility="{Binding CacheHitRate, Converter={StaticResource UsageCountVisibilityConverter}}" />
                </StackPanel>
            </StackPanel>
        </DataTemplate>

        <DataTemplate x:Key="FallbackContentTemplate">
            <snuxcc:ChatObjectSegmentView Value="{Binding}" />
        </DataTemplate>

        <snuxcc:ChatContentTemplateSelector
            x:Key="ChatContentTemplateSelector"
            FallbackTemplate="{StaticResource FallbackContentTemplate}"
            FunctionCallTemplate="{StaticResource FunctionCallContentTemplate}"
            FunctionResultTemplate="{StaticResource FunctionResultContentTemplate}"
            ReasoningTemplate="{StaticResource ReasoningContentTemplate}"
            TextTemplate="{StaticResource TextContentTemplate}"
            UsageTemplate="{StaticResource UsageContentTemplate}" />
    </UserControl.Resources>

    <Border
        x:Name="MessageBorder"
        Padding="8"
        HorizontalAlignment="Stretch"
        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
        BorderThickness="1"
        CornerRadius="{ThemeResource ControlCornerRadius}">
        <StackPanel HorizontalAlignment="Stretch" Spacing="4">
            <TextBlock
                x:Name="HeaderTextBlock"
                FontSize="12"
                FontWeight="SemiBold"
                Opacity="0.7" />

            <TextBlock
                x:Name="UserMessageTextBlock"
                FontSize="14"
                IsTextSelectionEnabled="True"
                TextWrapping="Wrap" />

            <ItemsControl x:Name="ContentItemsControl" ItemTemplateSelector="{StaticResource ChatContentTemplateSelector}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Spacing="4" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>
        </StackPanel>
    </Border>
</UserControl>
