<UserControl
    x:Class="Snap.Nicole.UI.Xaml.Controls.ChatElements.ChatFunctionResultSegmentView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:snuxcc="using:Snap.Nicole.UI.Xaml.Controls.ChatElements"
    xmlns:snuxm="using:Snap.Nicole.UI.Xaml.Markup">
    <Border
        Padding="8"
        Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
        BorderThickness="1"
        CornerRadius="{ThemeResource ControlCornerRadius}">
        <Grid ColumnSpacing="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>
            <FontIcon
                Grid.Column="0"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                FontSize="12"
                Glyph="&#xEC7A;" />

            <FontIcon
                Grid.Column="1"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                FontSize="12"
                Glyph="&#xE76B;" />

            <TextBlock
                Grid.Column="2"
                Opacity="0.7"
                Style="{ThemeResource CaptionTextBlockStyle}"
                Text="{x:Bind FunctionResult.Result}" />
            <TextBlock
                Grid.Column="3"
                Opacity="0.7"
                Style="{ThemeResource CaptionTextBlockStyle}"
                Text="{x:Bind FunctionResult.Exception}" />
        </Grid>
    </Border>
</UserControl>
