<UserControl
    x:Class="Snap.Nicole.UI.Xaml.Controls.ChatElements.ChatMarkdownSegmentView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:snuxcc="using:Snap.Nicole.UI.Xaml.Controls.ChatElements"
    xmlns:snuxd="using:Snap.Nicole.UI.Xaml.Data"
    x:Name="Root">

    <UserControl.Resources>
        <snuxd:EmptyStringToVisibilityConverter x:Key="TitleVisibilityConverter" />
    </UserControl.Resources>

    <StackPanel Spacing="2">
        <TextBlock
            FontSize="12"
            FontWeight="SemiBold"
            Opacity="0.7"
            Text="{Binding Title, ElementName=Root}"
            Visibility="{Binding Title, ElementName=Root, Converter={StaticResource TitleVisibilityConverter}}" />
        <snuxcc:MarkdownTextBlock Markdown="{Binding Markdown, ElementName=Root}" />
    </StackPanel>
</UserControl>
