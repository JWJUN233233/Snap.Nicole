<UserControl
    x:Class="Snap.Nicole.UI.Xaml.Controls.ChatMessageView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:snuxc="using:Snap.Nicole.UI.Xaml.Controls"
    mc:Ignorable="d">

    <UserControl.Resources>
        <DataTemplate x:Key="TextContentTemplate">
            <snuxc:ChatMarkdownSegmentView
                Markdown="{Binding Text}"
                Title="Answer" />
        </DataTemplate>

        <DataTemplate x:Key="ReasoningContentTemplate">
            <snuxc:ChatMarkdownSegmentView
                Markdown="{Binding Text}"
                Title="Thinking" />
        </DataTemplate>

        <DataTemplate x:Key="FunctionCallContentTemplate">
            <snuxc:ChatFunctionCallSegmentView FunctionCall="{Binding}" />
        </DataTemplate>

        <DataTemplate x:Key="FunctionResultContentTemplate">
            <snuxc:ChatFunctionResultSegmentView FunctionResult="{Binding}" />
        </DataTemplate>

        <DataTemplate x:Key="FallbackContentTemplate">
            <snuxc:ChatObjectSegmentView Value="{Binding}" />
        </DataTemplate>

        <snuxc:ChatContentTemplateSelector
            x:Key="ChatContentTemplateSelector"
            FallbackTemplate="{StaticResource FallbackContentTemplate}"
            FunctionCallTemplate="{StaticResource FunctionCallContentTemplate}"
            FunctionResultTemplate="{StaticResource FunctionResultContentTemplate}"
            ReasoningTemplate="{StaticResource ReasoningContentTemplate}"
            TextTemplate="{StaticResource TextContentTemplate}" />
    </UserControl.Resources>

    <Border
        x:Name="MessageBorder"
        Padding="0,0,0,8"
        HorizontalAlignment="Stretch"
        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
        BorderThickness="0,0,0,1">
        <StackPanel
            HorizontalAlignment="Stretch"
            Spacing="4">
            <TextBlock
                x:Name="HeaderTextBlock"
                FontSize="12"
                FontWeight="SemiBold"
                Opacity="0.6" />

            <TextBlock
                x:Name="UserMessageTextBlock"
                FontSize="14"
                IsTextSelectionEnabled="True"
                TextWrapping="Wrap" />

            <ItemsControl
                x:Name="ContentItemsControl"
                ItemTemplateSelector="{StaticResource ChatContentTemplateSelector}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Spacing="4" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>
        </StackPanel>
    </Border>
</UserControl>
