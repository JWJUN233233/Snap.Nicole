<Window
    x:Class="Snap.Nicole.UI.Xaml.Windows.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:snuxm="using:Snap.Nicole.UI.Xaml.Markup"
    xmlns:snuxp="using:Snap.Nicole.UI.Xaml.Pages"
    Title="Snap.Nicole"
    mc:Ignorable="d">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <NavigationView
        x:Name="Root"
        IsBackButtonVisible="Collapsed"
        IsSettingsVisible="True"
        ItemInvoked="OnNavigationItemInvoked"
        Loaded="OnLoaded">
        <NavigationView.MenuItems>
            <NavigationViewItem
                snuxm:NavigationExtensions.NavigateTo="snuxp:HomePage"
                Content="{snuxm:StringResource Name=HomePageTitle}"
                Icon="{snuxm:FontIcon Glyph=&#xE80F;}" />
        </NavigationView.MenuItems>
        <Frame x:Name="ContentFrame" />
    </NavigationView>
</Window>
