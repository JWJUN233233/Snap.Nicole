<Window
    x:Class="Snap.Nicole.UI.Xaml.Windows.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:mxi="using:Microsoft.Xaml.Interactivity"
    xmlns:snux="using:Snap.Nicole.UI.Xaml"
    xmlns:snuxb="using:Snap.Nicole.UI.Xaml.Behaviors"
    xmlns:snuxm="using:Snap.Nicole.UI.Xaml.Markup"
    xmlns:snuxp="using:Snap.Nicole.UI.Xaml.Pages"
    Title="Snap.Nicole"
    mc:Ignorable="d">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TitleBar
            x:Name="TitleBarElement"
            Title="{snuxm:StringResource Name=UIShellNotifyIconContextMenuFlyoutLabelAppName}"
            Grid.Row="0"
            IsBackButtonVisible="{x:Bind ContentFrame.CanGoBack, Mode=OneWay}"
            IsPaneToggleButtonVisible="True">
            <TitleBar.Resources>
                <x:Double x:Key="TitleBarLeftPaddingWidth">40</x:Double>
                <x:Double x:Key="TitleBarCompactHeight">44</x:Double>
                <x:Double x:Key="TitleBarExpandedHeight">44</x:Double>
                <x:Double x:Key="TitleBarMinDragRegionWidth">0</x:Double>
            </TitleBar.Resources>
            <mxi:Interaction.Behaviors>
                <snuxb:TitleBarBehavior />
            </mxi:Interaction.Behaviors>
        </TitleBar>

        <NavigationView
            x:Name="NavView"
            Grid.Row="1"
            CompactPaneLength="45"
            IsBackButtonVisible="Collapsed"
            IsPaneOpen="True"
            IsPaneToggleButtonVisible="False"
            IsSettingsVisible="True"
            ItemInvoked="OnNavigationItemInvoked"
            Loaded="OnLoaded"
            OpenPaneLength="205">
            <NavigationView.MenuItems>
                <NavigationViewItem
                    snux:NavigationExtensions.NavigateTo="snuxp:HomePage"
                    Content="{snuxm:StringResource Name=UIXamlWindowsMainWindowNavigationViewItemHomePageContent}"
                    Icon="{snuxm:FontIcon Glyph=&#xE80F;}" />
                <NavigationViewItem
                    snux:NavigationExtensions.NavigateTo="snuxp:ChatPage"
                    Content="{snuxm:StringResource Name=UIXamlWindowsMainWindowNavigationViewItemChatPageContent}"
                    Icon="{snuxm:FontIcon Glyph=&#xE76E;}" />
            </NavigationView.MenuItems>
            <Frame x:Name="ContentFrame" Transitions="{ThemeResource NavigationThemeTransitions}" />
        </NavigationView>
    </Grid>

</Window>
