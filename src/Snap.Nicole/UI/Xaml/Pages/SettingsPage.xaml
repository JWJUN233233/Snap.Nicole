<Page
    x:Class="Snap.Nicole.UI.Xaml.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:cwcont="using:CommunityToolkit.WinUI.Controls"
    xmlns:cwconv="using:CommunityToolkit.WinUI.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:mxi="using:Microsoft.Xaml.Interactivity"
    xmlns:snuxb="using:Snap.Nicole.UI.Xaml.Behaviors"
    xmlns:snuxd="using:Snap.Nicole.UI.Xaml.Data"
    xmlns:snuxm="using:Snap.Nicole.UI.Xaml.Markup"
    xmlns:snvs="using:Snap.Nicole.ViewModels.Settings"
    d:DataContext="{d:DesignInstance snvs:SettingsViewModel}"
    mc:Ignorable="d">

    <mxi:Interaction.Behaviors>
        <snuxb:DisposeDataContextOnUnloadedBehavior />
        <snuxb:InvokeCommandOnLoadedBehavior Command="{Binding GitSync.RefreshRepositoryStateCommand}" />
    </mxi:Interaction.Behaviors>

    <Page.Resources>
        <cwconv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <cwconv:DoubleToVisibilityConverter x:Key="PositiveCountVisibilityConverter" GreaterThan="0" />
        <snuxd:EmptyObjectToVisibilityConverter x:Key="ModelProviderProfileEditorVisibilityConverter" />
        <snuxd:EmptyObjectToVisibilityConverter x:Key="ModelProviderProfileEmptyStateVisibilityConverter" IsInverted="True" />
        <snuxd:NullableNumberBoxValueConverter x:Key="NullableNumberBoxValueConverter" />
    </Page.Resources>

    <Pivot Style="{StaticResource DefaultPivotStyle}">
        <Pivot.Resources>
            <Thickness x:Key="PivotHeaderItemMargin">24,0,0,0</Thickness>
            <Thickness x:Key="PivotItemMargin">0</Thickness>
        </Pivot.Resources>
        <PivotItem Header="常规">
            <ScrollViewer>
                <StackPanel Margin="24" Spacing="16">
                    <Border
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        CornerRadius="{ThemeResource ControlCornerRadius}">
                        <StackPanel Padding="16" Spacing="16">
                            <TextBlock
                                Grid.Column="0"
                                Margin="1,0,0,0"
                                Style="{ThemeResource BaseTextBlockStyle}"
                                Text="{snuxm:StringResource Name=UIXamlPagesSettingsPageLabelSettingsSync}" />

                            <Border
                                Padding="16"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="{ThemeResource ControlCornerRadius}"
                                Visibility="{Binding GitSync.IsSetupVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                                <StackPanel Spacing="12">
                                    <TextBox
                                        IsEnabled="{Binding GitSync.IsRepositoryUrlEnabled}"
                                        PlaceholderText="{snuxm:StringResource Name=UIXamlPagesSettingsPagePlaceholderRepositoryUrl}"
                                        Text="{Binding GitSync.RepositoryUrl, Mode=TwoWay}">
                                        <TextBox.Header>
                                            <TextBlock Margin="1,0,0,0" Text="{snuxm:StringResource Name=UIXamlPagesSettingsPageLabelRepositoryUrl}" />
                                        </TextBox.Header>
                                        <TextBox.Description>
                                            <TextBlock
                                                Margin="1,3,0,0"
                                                Style="{ThemeResource CaptionTextBlockStyle}"
                                                Text="{snuxm:StringResource Name=UIXamlPagesSettingsPageDescriptionCreateEmptyRepository}" />
                                        </TextBox.Description>
                                    </TextBox>
                                    <Button HorizontalAlignment="Left" Command="{Binding GitSync.InitializeRepositoryCommand}">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <FontIcon FontSize="16" Glyph="&#xE8B5;" />
                                            <TextBlock Text="{snuxm:StringResource Name=UIXamlPagesSettingsPageLabelEnableSync}" />
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </Border>

                            <StackPanel Spacing="3">
                                <cwcont:SettingsCard Description="{snuxm:StringResource Name=UIXamlPagesSettingsPageDescriptionSettingsSync}" Header="{snuxm:StringResource Name=UIXamlPagesSettingsPageLabelGitSync}">
                                    <StackPanel
                                        Grid.Column="1"
                                        Orientation="Horizontal"
                                        Spacing="8">

                                        <StackPanel
                                            VerticalAlignment="Center"
                                            Orientation="Horizontal"
                                            Spacing="8"
                                            Visibility="{Binding GitSync.IsProgressVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                                            <ProgressRing
                                                Width="20"
                                                Height="20"
                                                IsActive="{Binding GitSync.IsBusy}" />
                                            <TextBlock
                                                VerticalAlignment="Center"
                                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                Text="{Binding GitSync.CurrentOperationText.Value}" />
                                        </StackPanel>

                                        <Button
                                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                            Command="{Binding GitSync.RefreshRepositoryStateCommand}"
                                            ToolTipService.ToolTip="{snuxm:StringResource Name=UIXamlPagesSettingsPageLabelRefreshGitState}">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <FontIcon FontSize="16" Glyph="&#xE72C;" />
                                                <TextBlock Text="{snuxm:StringResource Name=UIXamlPagesSettingsPageLabelRefreshGitState}" />
                                            </StackPanel>
                                        </Button>

                                        <StackPanel
                                            Orientation="Horizontal"
                                            Spacing="8"
                                            Visibility="{Binding GitSync.IsOperationsVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                                            <Button BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" Command="{Binding GitSync.PullRepositoryCommand}">
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <FontIcon FontSize="16" Glyph="&#xE896;" />
                                                    <TextBlock Text="{snuxm:StringResource Name=UIXamlPagesSettingsPageLabelPull}" />
                                                </StackPanel>
                                            </Button>

                                            <Button BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" Command="{Binding GitSync.PushRepositoryCommand}">
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <FontIcon FontSize="16" Glyph="&#xE898;" />
                                                    <TextBlock Text="{snuxm:StringResource Name=UIXamlPagesSettingsPageLabelPush}" />
                                                </StackPanel>
                                            </Button>
                                        </StackPanel>
                                    </StackPanel>
                                </cwcont:SettingsCard>
                                <InfoBar
                                    Title="{Binding GitSync.StatusTitle.Value}"
                                    IsClosable="False"
                                    IsOpen="{Binding GitSync.IsStatusOpen, Mode=TwoWay}"
                                    Message="{Binding GitSync.StatusMessage.Value}"
                                    Severity="{Binding GitSync.InfoBarSeverity}" />
                                <cwcont:SettingsCard
                                    Grid.Row="0"
                                    Description="{Binding GitSync.RepositoryPath}"
                                    Header="{snuxm:StringResource Name=UIXamlPagesSettingsPageLabelRepositoryPath}">
                                    <Button BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" Command="{Binding GitSync.OpenSettingsFolderCommand}">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <FontIcon FontSize="16" Glyph="&#xE8DA;" />
                                            <TextBlock Text="{snuxm:StringResource Name=UIXamlPagesSettingsPageLabelOpenSettingsFolder}" />
                                        </StackPanel>
                                    </Button>
                                </cwcont:SettingsCard>
                                <cwcont:SettingsCard
                                    Grid.Row="1"
                                    Description="{Binding GitSync.RemoteUrlDisplay.Value}"
                                    Header="{snuxm:StringResource Name=UIXamlPagesSettingsPageLabelRemoteRepository}" />
                            </StackPanel>

                        </StackPanel>
                    </Border>

                    <Border
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        CornerRadius="{ThemeResource ControlCornerRadius}">
                        <StackPanel Padding="16" Spacing="16">
                            <TextBlock
                                Margin="1,0,0,0"
                                Style="{ThemeResource BaseTextBlockStyle}"
                                Text="{snuxm:StringResource Name=UIXamlPagesSettingsPageLabelAppearance}" />
                            <cwcont:SettingsCard Header="{snuxm:StringResource Name=UIXamlPagesSettingsPageLabelLanguage}">
                                <ComboBox
                                    MinWidth="160"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    DisplayMemberPath="Label">
                                    <mxi:Interaction.Behaviors>
                                        <snuxb:SelectorSelectedValueBindingWorkaroundBehavior
                                            ItemsSource="{Binding Languages}"
                                            SelectedValue="{Binding Settings.Language, Mode=TwoWay}"
                                            SelectedValuePath="Value" />
                                    </mxi:Interaction.Behaviors>
                                </ComboBox>
                            </cwcont:SettingsCard>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </PivotItem>

        <PivotItem Header="智能体">
            <ScrollViewer>
                <StackPanel Margin="24" Spacing="16">
                    <Border
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        CornerRadius="{ThemeResource ControlCornerRadius}"
                        DataContext="{Binding ModelConfiguration}">
                        <StackPanel Padding="16" Spacing="16">
                            <TextBlock
                                Margin="1,0,0,0"
                                Style="{ThemeResource BaseTextBlockStyle}"
                                Text="{snuxm:StringResource Name=UIXamlPagesSettingsPageLabelModelProviderProfiles}" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition />
                                </Grid.ColumnDefinitions>

                                <Border
                                    Grid.Column="0"
                                    Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1,1,0,1"
                                    CornerRadius="{Binding Source={ThemeResource ControlCornerRadius}, Converter={StaticResource LeftCornerRadiusFilterConverter}}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition />
                                        </Grid.RowDefinitions>
                                        <Grid
                                            Grid.Row="0"
                                            Padding="16"
                                            ColumnSpacing="8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition />
                                                <ColumnDefinition />
                                            </Grid.ColumnDefinitions>
                                            <Button
                                                Grid.Column="0"
                                                HorizontalAlignment="Stretch"
                                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                                Command="{Binding AddProfileCommand}">
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <FontIcon FontSize="16" Glyph="&#xE710;" />
                                                    <TextBlock Text="{snuxm:StringResource Name=UIXamlPagesSettingsPageLabelAddProfile}" />
                                                </StackPanel>
                                            </Button>
                                            <Button
                                                Grid.Column="1"
                                                HorizontalAlignment="Stretch"
                                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                                Command="{Binding DeleteProfileCommand}">
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <FontIcon FontSize="16" Glyph="&#xE74D;" />
                                                    <TextBlock Text="{snuxm:StringResource Name=UIXamlPagesSettingsPageLabelDeleteProfile}" />
                                                </StackPanel>
                                            </Button>
                                        </Grid>

                                        <ListView
                                            Grid.Row="1"
                                            AllowDrop="True"
                                            CanReorderItems="True"
                                            DisplayMemberPath="Name">
                                            <mxi:Interaction.Behaviors>
                                                <snuxb:SelectorSelectedItemBindingWorkaroundBehavior ItemsSource="{Binding Settings.ModelProviderProfiles}" SelectedItem="{Binding Settings.ModelProviderProfiles.CurrentItem, Mode=TwoWay}" />
                                            </mxi:Interaction.Behaviors>
                                        </ListView>
                                    </Grid>
                                </Border>

                                <Border
                                    Grid.Column="1"
                                    Padding="16"
                                    Background="{ThemeResource CardBackgroundFillColorTertiaryBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="0,1,1,1"
                                    CornerRadius="{Binding Source={ThemeResource ControlCornerRadius}, Converter={StaticResource RightCornerRadiusFilterConverter}}">
                                    <Grid>
                                        <StackPanel Spacing="16" Visibility="{Binding Settings.ModelProviderProfiles.CurrentItem, Converter={StaticResource ModelProviderProfileEditorVisibilityConverter}}">
                                            <TextBox
                                                Header="{snuxm:StringResource Name=UIXamlPagesSettingsPageLabelProfileName}"
                                                IsSpellCheckEnabled="False"
                                                Text="{Binding Settings.ModelProviderProfiles.CurrentItem.Name, Mode=TwoWay}" />
                                            <ComboBox
                                                MinWidth="240"
                                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                                DisplayMemberPath="Label"
                                                Header="{snuxm:StringResource Name=UIXamlPagesSettingsPageLabelProfileProviderType}">
                                                <mxi:Interaction.Behaviors>
                                                    <snuxb:SelectorSelectedValueBindingWorkaroundBehavior
                                                        ItemsSource="{Binding ModelProviderTypes}"
                                                        SelectedValue="{Binding Settings.ModelProviderProfiles.CurrentItem.ProviderType, Mode=TwoWay}"
                                                        SelectedValuePath="Value" />
                                                </mxi:Interaction.Behaviors>
                                            </ComboBox>
                                            <TextBox Header="{snuxm:StringResource Name=UIXamlPagesSettingsPageLabelProfileEndpoint}" Text="{Binding Settings.ModelProviderProfiles.CurrentItem.Endpoint, Mode=TwoWay}" />
                                            <PasswordBox
                                                Description="{snuxm:StringResource Name=UIXamlPagesSettingsPageDescriptionProfileApiKey}"
                                                Header="{snuxm:StringResource Name=UIXamlPagesSettingsPageLabelProfileApiKey}"
                                                PasswordChar="&#x2022;"
                                                PasswordRevealMode="Peek">
                                                <mxi:Interaction.Behaviors>
                                                    <snuxb:PasswordBoxBindingBehavior Password="{Binding Settings.ModelProviderProfiles.CurrentItem.ApiKey, Mode=TwoWay}" />
                                                </mxi:Interaction.Behaviors>
                                            </PasswordBox>

                                            <StackPanel Spacing="3">
                                                <cwcont:SettingsCard Description="{snuxm:StringResource Name=UIXamlPagesSettingsPageDescriptionModelListDocumentationLink}" Header="{snuxm:StringResource Name=UIXamlPagesSettingsPageLabelModelListDocumentationLink}">
                                                    <TextBox Text="{Binding Settings.ModelProviderProfiles.CurrentItem.ModelListDocumentationLink, Mode=TwoWay}" />
                                                </cwcont:SettingsCard>
                                                <cwcont:SettingsCard Header="{snuxm:StringResource Name=UIXamlPagesSettingsPageLabelModelListActions}">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <Button
                                                            Grid.Column="1"
                                                            VerticalAlignment="Top"
                                                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                                            Command="{Binding RefreshModelsCommand}">
                                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                                <FontIcon FontSize="16" Glyph="&#xE72C;" />
                                                                <TextBlock Text="{snuxm:StringResource Name=UIXamlPagesSettingsPageLabelFetchModels}" />
                                                            </StackPanel>
                                                        </Button>
                                                        <Button
                                                            Grid.Column="2"
                                                            VerticalAlignment="Top"
                                                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                                            Command="{Binding AddModelCommand}">
                                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                                <FontIcon FontSize="16" Glyph="&#xE710;" />
                                                                <TextBlock Text="{snuxm:StringResource Name=UIXamlPagesSettingsPageLabelAddModel}" />
                                                            </StackPanel>
                                                        </Button>
                                                        <Button
                                                            Grid.Column="3"
                                                            VerticalAlignment="Top"
                                                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                                            Command="{Binding DeleteModelCommand}">
                                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                                <FontIcon FontSize="16" Glyph="&#xE74D;" />
                                                                <TextBlock Text="{snuxm:StringResource Name=UIXamlPagesSettingsPageLabelDeleteModel}" />
                                                            </StackPanel>
                                                        </Button>
                                                        <Button
                                                            Grid.Column="4"
                                                            VerticalAlignment="Top"
                                                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                                            Command="{Binding ClearModelsCommand}">
                                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                                <FontIcon FontSize="16" Glyph="&#xE894;" />
                                                                <TextBlock Text="{snuxm:StringResource Name=UIXamlPagesSettingsPageLabelClearModels}" />
                                                            </StackPanel>
                                                        </Button>
                                                    </StackPanel>
                                                </cwcont:SettingsCard>
                                                <InfoBar
                                                    Title="{Binding ModelListStatusTitle.Value}"
                                                    IsClosable="False"
                                                    IsOpen="{Binding IsModelListStatusOpen, Mode=TwoWay}"
                                                    Message="{Binding ModelListStatusMessage.Value}"
                                                    Severity="{Binding ModelListInfoBarSeverity}"
                                                    Visibility="{Binding IsModelListStatusOpen, Mode=OneWay}" />
                                                <cwcont:SettingsCard Header="{snuxm:StringResource Name=UIXamlPagesSettingsPageLabelSelectedModel}">
                                                    <ComboBox
                                                        MinWidth="240"
                                                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                                        DisplayMemberPath="DisplayName">
                                                        <mxi:Interaction.Behaviors>
                                                            <snuxb:SelectorSelectedItemBindingWorkaroundBehavior ItemsSource="{Binding Settings.ModelProviderProfiles.CurrentItem.ModelProfiles, Mode=OneWay}" SelectedItem="{Binding Settings.ModelProviderProfiles.CurrentItem.ModelProfiles.CurrentItem, Mode=TwoWay}" />
                                                        </mxi:Interaction.Behaviors>
                                                    </ComboBox>
                                                </cwcont:SettingsCard>
                                                <cwcont:SettingsCard Header="{snuxm:StringResource Name=UIXamlPagesSettingsPageLabelProfileModelId}">
                                                    <TextBox Text="{Binding Settings.ModelProviderProfiles.CurrentItem.ModelProfiles.CurrentItem.ModelId, Mode=TwoWay}" />
                                                </cwcont:SettingsCard>
                                                <cwcont:SettingsCard Header="{snuxm:StringResource Name=UIXamlPagesSettingsPageLabelModelName}">
                                                    <TextBox Text="{Binding Settings.ModelProviderProfiles.CurrentItem.ModelProfiles.CurrentItem.Name, Mode=TwoWay}" />
                                                </cwcont:SettingsCard>
                                                <cwcont:SettingsExpander Header="{snuxm:StringResource Name=UIXamlPagesSettingsPageLabelModelAgentOptions}" IsExpanded="True">
                                                    <cwcont:SettingsExpander.Items>
                                                        <cwcont:SettingsCard Padding="16,8,44,8" Header="{snuxm:StringResource Name=UIXamlPagesSettingsPageLabelModelTemperature}">
                                                            <NumberBox
                                                                LargeChange="0.5"
                                                                Maximum="2"
                                                                Minimum="0"
                                                                PlaceholderText="{snuxm:StringResource Name=UIXamlPagesSettingsPagePlaceholderProviderDefault}"
                                                                SmallChange="0.1"
                                                                SpinButtonPlacementMode="Compact"
                                                                Value="{Binding Settings.ModelProviderProfiles.CurrentItem.ModelProfiles.CurrentItem.AgentOptions.Temperature, Mode=TwoWay, Converter={StaticResource NullableNumberBoxValueConverter}}" />
                                                        </cwcont:SettingsCard>
                                                        <cwcont:SettingsCard Padding="16,8,44,8" Header="{snuxm:StringResource Name=UIXamlPagesSettingsPageLabelModelTopP}">
                                                            <NumberBox
                                                                LargeChange="0.1"
                                                                Maximum="1"
                                                                Minimum="0"
                                                                PlaceholderText="{snuxm:StringResource Name=UIXamlPagesSettingsPagePlaceholderProviderDefault}"
                                                                SmallChange="0.05"
                                                                SpinButtonPlacementMode="Compact"
                                                                Value="{Binding Settings.ModelProviderProfiles.CurrentItem.ModelProfiles.CurrentItem.AgentOptions.TopP, Mode=TwoWay, Converter={StaticResource NullableNumberBoxValueConverter}}" />
                                                        </cwcont:SettingsCard>
                                                        <cwcont:SettingsCard Padding="16,8,44,8" Header="{snuxm:StringResource Name=UIXamlPagesSettingsPageLabelModelReasoningEffort}">
                                                            <ComboBox
                                                                MinWidth="180"
                                                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                                                DisplayMemberPath="Label"
                                                                PlaceholderText="{snuxm:StringResource Name=UIXamlPagesSettingsPagePlaceholderProviderDefault}">
                                                                <mxi:Interaction.Behaviors>
                                                                    <snuxb:SelectorSelectedValueBindingWorkaroundBehavior
                                                                        ItemsSource="{Binding ReasoningEfforts}"
                                                                        SelectedValue="{Binding Settings.ModelProviderProfiles.CurrentItem.ModelProfiles.CurrentItem.AgentOptions.ReasoningEffort, Mode=TwoWay}"
                                                                        SelectedValuePath="Value" />
                                                                </mxi:Interaction.Behaviors>
                                                            </ComboBox>
                                                        </cwcont:SettingsCard>
                                                        <cwcont:SettingsCard Padding="16,8,44,8" Header="{snuxm:StringResource Name=UIXamlPagesSettingsPageLabelModelThinkingEnabled}">
                                                            <ToggleSwitch IsOn="{Binding Settings.ModelProviderProfiles.CurrentItem.ModelProfiles.CurrentItem.AgentOptions.ThinkingEnabled, Mode=TwoWay}" />
                                                        </cwcont:SettingsCard>
                                                        <cwcont:SettingsCard Padding="16,8,44,8" Header="{snuxm:StringResource Name=UIXamlPagesSettingsPageLabelModelOmitReasoningEffortWhenThinkingDisabled}">
                                                            <ToggleSwitch IsOn="{Binding Settings.ModelProviderProfiles.CurrentItem.ModelProfiles.CurrentItem.AgentOptions.OmitReasoningEffortWhenThinkingDisabled, Mode=TwoWay}" />
                                                        </cwcont:SettingsCard>
                                                        <cwcont:SettingsCard Padding="16,8,44,8" Header="{snuxm:StringResource Name=UIXamlPagesSettingsPageLabelModelMaxInputTokens}">
                                                            <NumberBox
                                                                LargeChange="1024"
                                                                Maximum="2147483647"
                                                                Minimum="0"
                                                                PlaceholderText="{snuxm:StringResource Name=UIXamlPagesSettingsPagePlaceholderProviderDefault}"
                                                                SmallChange="1024"
                                                                SpinButtonPlacementMode="Compact"
                                                                Value="{Binding Settings.ModelProviderProfiles.CurrentItem.ModelProfiles.CurrentItem.AgentOptions.MaxInputTokens, Mode=TwoWay, Converter={StaticResource NullableNumberBoxValueConverter}}" />
                                                        </cwcont:SettingsCard>
                                                        <cwcont:SettingsCard Padding="16,8,44,8" Header="{snuxm:StringResource Name=UIXamlPagesSettingsPageLabelModelMaxOutputTokens}">
                                                            <NumberBox
                                                                LargeChange="1024"
                                                                Maximum="2147483647"
                                                                Minimum="0"
                                                                PlaceholderText="{snuxm:StringResource Name=UIXamlPagesSettingsPagePlaceholderProviderDefault}"
                                                                SmallChange="1024"
                                                                SpinButtonPlacementMode="Compact"
                                                                Value="{Binding Settings.ModelProviderProfiles.CurrentItem.ModelProfiles.CurrentItem.AgentOptions.MaxOutputTokens, Mode=TwoWay, Converter={StaticResource NullableNumberBoxValueConverter}}" />
                                                        </cwcont:SettingsCard>
                                                        <cwcont:SettingsCard Padding="16,8,44,8" Header="{snuxm:StringResource Name=UIXamlPagesSettingsPageLabelModelSystemPrompt}">
                                                            <TextBox
                                                                AcceptsReturn="True"
                                                                ScrollViewer.VerticalScrollBarVisibility="Auto"
                                                                Text="{Binding Settings.ModelProviderProfiles.CurrentItem.ModelProfiles.CurrentItem.AgentOptions.SystemPrompt, Mode=TwoWay}"
                                                                TextWrapping="Wrap" />
                                                        </cwcont:SettingsCard>
                                                    </cwcont:SettingsExpander.Items>
                                                </cwcont:SettingsExpander>
                                            </StackPanel>

                                        </StackPanel>
                                        <StackPanel
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Spacing="8"
                                            Visibility="{Binding Settings.ModelProviderProfiles.CurrentItem, Converter={StaticResource ModelProviderProfileEmptyStateVisibilityConverter}}">
                                            <FontIcon
                                                HorizontalAlignment="Center"
                                                FontSize="24"
                                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                Glyph="&#xE70F;" />
                                            <TextBlock
                                                MaxWidth="320"
                                                HorizontalAlignment="Center"
                                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                Text="{snuxm:StringResource Name=UIXamlPagesSettingsPageDescriptionSelectModelProviderProfileToEdit}"
                                                TextAlignment="Center"
                                                TextWrapping="WrapWholeWords"
                                                Visibility="{Binding Settings.ModelProviderProfiles.Count, Converter={StaticResource PositiveCountVisibilityConverter}}" />
                                            <TextBlock
                                                MaxWidth="320"
                                                HorizontalAlignment="Center"
                                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                Text="{snuxm:StringResource Name=UIXamlPagesSettingsPageDescriptionAddModelProviderProfileToEdit}"
                                                TextAlignment="Center"
                                                TextWrapping="WrapWholeWords"
                                                Visibility="{Binding Settings.ModelProviderProfiles.Count, Converter={StaticResource PositiveCountVisibilityConverter}, ConverterParameter=True}" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </Grid>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>
        </PivotItem>
    </Pivot>
</Page>
