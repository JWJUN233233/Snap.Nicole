<Page
    x:Class="Snap.Nicole.UI.Xaml.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:cvt="using:CommunityToolkit.WinUI.Converters"
    xmlns:cwc="using:CommunityToolkit.WinUI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:mxi="using:Microsoft.Xaml.Interactivity"
    xmlns:snuxb="using:Snap.Nicole.UI.Xaml.Behaviors"
    xmlns:snuxc="using:Snap.Nicole.UI.Xaml.Controls"
    xmlns:snuxd="using:Snap.Nicole.UI.Xaml.Data"
    xmlns:snuxm="using:Snap.Nicole.UI.Xaml.Markup"
    xmlns:snvs="using:Snap.Nicole.ViewModels.Settings"
    d:DataContext="{d:DesignInstance snvs:SettingsViewModel}"
    mc:Ignorable="d">

    <mxi:Interaction.Behaviors>
        <snuxb:DisposeDataContextOnUnloadedBehavior />
    </mxi:Interaction.Behaviors>

    <Page.Resources>
        <cvt:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <snuxd:EmptyObjectToVisibilityConverter x:Key="ModelProviderProfileEditorVisibilityConverter" />
        <snuxd:EmptyObjectToVisibilityConverter x:Key="ModelProviderProfileEmptyStateVisibilityConverter" IsInverted="True" />
    </Page.Resources>

    <ScrollViewer>
        <mxi:Interaction.Behaviors>
            <snuxb:InvokeCommandOnLoadedBehavior Command="{Binding GitSync.RefreshRepositoryStateCommand}" />
        </mxi:Interaction.Behaviors>

        <StackPanel Margin="24" Spacing="24">
            <Border
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                CornerRadius="{ThemeResource ControlCornerRadius}">
                <StackPanel Padding="16" Spacing="16">
                    <TextBlock
                        Grid.Column="0"
                        Margin="1,0,0,0"
                        Style="{ThemeResource BaseTextBlockStyle}"
                        Text="{snuxm:StringResource Name=UIXamlPagesSettingsPageLabelSettingsSync}" />

                    <Border
                        Padding="16"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="{ThemeResource ControlCornerRadius}"
                        Visibility="{Binding GitSync.IsSetupVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel Spacing="12">
                            <TextBox
                                IsEnabled="{Binding GitSync.IsRepositoryUrlEnabled}"
                                PlaceholderText="{snuxm:StringResource Name=UIXamlPagesSettingsPagePlaceholderRepositoryUrl}"
                                Text="{Binding GitSync.RepositoryUrl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                <TextBox.Header>
                                    <TextBlock Margin="1,0,0,0" Text="{snuxm:StringResource Name=UIXamlPagesSettingsPageLabelRepositoryUrl}" />
                                </TextBox.Header>
                                <TextBox.Description>
                                    <TextBlock
                                        Margin="1,3,0,0"
                                        Style="{ThemeResource CaptionTextBlockStyle}"
                                        Text="{snuxm:StringResource Name=UIXamlPagesSettingsPageDescriptionCreateEmptyRepository}" />
                                </TextBox.Description>
                            </TextBox>
                            <Button HorizontalAlignment="Left" Command="{Binding GitSync.InitializeRepositoryCommand}">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon FontSize="16" Glyph="&#xE8B5;" />
                                    <TextBlock Text="{snuxm:StringResource Name=UIXamlPagesSettingsPageLabelEnableSync}" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>

                    <StackPanel Spacing="3">
                        <cwc:SettingsCard Description="{snuxm:StringResource Name=UIXamlPagesSettingsPageDescriptionSettingsSync}" Header="{snuxm:StringResource Name=UIXamlPagesSettingsPageLabelGitSync}">
                            <StackPanel
                                Grid.Column="1"
                                Orientation="Horizontal"
                                Spacing="8">

                                <StackPanel
                                    VerticalAlignment="Center"
                                    Orientation="Horizontal"
                                    Spacing="8"
                                    Visibility="{Binding GitSync.IsProgressVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <ProgressRing
                                        Width="20"
                                        Height="20"
                                        IsActive="{Binding GitSync.IsBusy}" />
                                    <TextBlock
                                        VerticalAlignment="Center"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        Text="{Binding GitSync.CurrentOperationText.Value}" />
                                </StackPanel>

                                <Button
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    Command="{Binding GitSync.RefreshRepositoryStateCommand}"
                                    ToolTipService.ToolTip="{snuxm:StringResource Name=UIXamlPagesSettingsPageLabelRefreshGitState}">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon FontSize="16" Glyph="&#xE72C;" />
                                        <TextBlock Text="{snuxm:StringResource Name=UIXamlPagesSettingsPageLabelRefreshGitState}" />
                                    </StackPanel>
                                </Button>

                                <StackPanel
                                    Orientation="Horizontal"
                                    Spacing="8"
                                    Visibility="{Binding GitSync.IsOperationsVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <Button BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" Command="{Binding GitSync.PullRepositoryCommand}">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <FontIcon FontSize="16" Glyph="&#xE896;" />
                                            <TextBlock Text="{snuxm:StringResource Name=UIXamlPagesSettingsPageLabelPull}" />
                                        </StackPanel>
                                    </Button>

                                    <Button BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" Command="{Binding GitSync.PushRepositoryCommand}">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <FontIcon FontSize="16" Glyph="&#xE898;" />
                                            <TextBlock Text="{snuxm:StringResource Name=UIXamlPagesSettingsPageLabelPush}" />
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </StackPanel>
                        </cwc:SettingsCard>
                        <InfoBar
                            Title="{Binding GitSync.StatusTitle.Value}"
                            IsClosable="False"
                            IsOpen="{Binding GitSync.IsStatusOpen, Mode=TwoWay}"
                            Message="{Binding GitSync.StatusMessage.Value}"
                            Severity="{Binding GitSync.InfoBarSeverity}" />
                        <cwc:SettingsCard
                            Grid.Row="0"
                            Description="{Binding GitSync.RepositoryPath}"
                            Header="{snuxm:StringResource Name=UIXamlPagesSettingsPageLabelRepositoryPath}">
                            <Button BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" Command="{Binding GitSync.OpenSettingsFolderCommand}">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon FontSize="16" Glyph="&#xE8DA;" />
                                    <TextBlock Text="{snuxm:StringResource Name=UIXamlPagesSettingsPageLabelOpenSettingsFolder}" />
                                </StackPanel>
                            </Button>
                        </cwc:SettingsCard>
                        <cwc:SettingsCard
                            Grid.Row="1"
                            Description="{Binding GitSync.RemoteUrlDisplay.Value}"
                            Header="{snuxm:StringResource Name=UIXamlPagesSettingsPageLabelRemoteRepository}" />
                    </StackPanel>

                </StackPanel>
            </Border>

            <Border
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                CornerRadius="{ThemeResource ControlCornerRadius}">
                <StackPanel Padding="16" Spacing="16">
                    <TextBlock
                        Margin="1,0,0,0"
                        Style="{ThemeResource BaseTextBlockStyle}"
                        Text="{snuxm:StringResource Name=UIXamlPagesSettingsPageLabelAppearance}" />
                    <cwc:SettingsCard Header="{snuxm:StringResource Name=UIXamlPagesSettingsPageLabelLanguage}">
                        <ComboBox
                            MinWidth="160"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            DisplayMemberPath="Label"
                            ItemsSource="{Binding Languages}"
                            SelectedValue="{Binding Settings.Language, Mode=TwoWay}"
                            SelectedValuePath="Value" />
                    </cwc:SettingsCard>
                </StackPanel>
            </Border>

            <Border
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                CornerRadius="{ThemeResource ControlCornerRadius}"
                DataContext="{Binding ModelConfiguration}">
                <StackPanel Padding="16" Spacing="16">
                    <TextBlock
                        Margin="1,0,0,0"
                        Style="{ThemeResource BaseTextBlockStyle}"
                        Text="{snuxm:StringResource Name=UIXamlPagesSettingsPageLabelModelProviderProfiles}" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition />
                        </Grid.ColumnDefinitions>

                        <Border
                            Grid.Column="0"
                            Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1,1,0,1"
                            CornerRadius="{Binding Source={ThemeResource ControlCornerRadius}, Converter={StaticResource LeftCornerRadiusFilterConverter}}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition />
                                </Grid.RowDefinitions>
                                <Grid
                                    Grid.Row="0"
                                    Padding="16"
                                    ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition />
                                        <ColumnDefinition />
                                    </Grid.ColumnDefinitions>
                                    <Button
                                        Grid.Column="0"
                                        HorizontalAlignment="Stretch"
                                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                        Command="{Binding AddProfileCommand}">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <FontIcon FontSize="16" Glyph="&#xE710;" />
                                            <TextBlock Text="{snuxm:StringResource Name=UIXamlPagesSettingsPageLabelAddProfile}" />
                                        </StackPanel>
                                    </Button>
                                    <Button
                                        Grid.Column="1"
                                        HorizontalAlignment="Stretch"
                                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                        Command="{Binding DeleteProfileCommand}">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <FontIcon FontSize="16" Glyph="&#xE74D;" />
                                            <TextBlock Text="{snuxm:StringResource Name=UIXamlPagesSettingsPageLabelDeleteProfile}" />
                                        </StackPanel>
                                    </Button>
                                </Grid>

                                <ListView
                                    Grid.Row="1"
                                    AllowDrop="True"
                                    CanReorderItems="True"
                                    DisplayMemberPath="Name"
                                    ItemsSource="{Binding Settings.ModelProviderProfiles}"
                                    SelectedItem="{Binding Settings.ModelProviderProfiles.CurrentItem, Mode=TwoWay}" />
                            </Grid>
                        </Border>

                        <Border
                            Grid.Column="1"
                            Padding="16"
                            Background="{ThemeResource CardBackgroundFillColorTertiaryBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="0,1,1,1"
                            CornerRadius="{Binding Source={ThemeResource ControlCornerRadius}, Converter={StaticResource RightCornerRadiusFilterConverter}}">
                            <Grid>
                                <StackPanel Spacing="16" Visibility="{Binding Settings.ModelProviderProfiles.CurrentItem, Converter={StaticResource ModelProviderProfileEditorVisibilityConverter}}">
                                    <TextBox
                                        Header="{snuxm:StringResource Name=UIXamlPagesSettingsPageLabelProfileName}"
                                        IsSpellCheckEnabled="False"
                                        Text="{Binding Settings.ModelProviderProfiles.CurrentItem.Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <ComboBox
                                        MinWidth="240"
                                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                        DisplayMemberPath="Label"
                                        Header="{snuxm:StringResource Name=UIXamlPagesSettingsPageLabelProfileProviderType}"
                                        ItemsSource="{Binding ModelProviderTypes}"
                                        SelectedValue="{Binding Settings.ModelProviderProfiles.CurrentItem.ProviderType, Mode=TwoWay}"
                                        SelectedValuePath="Value" />
                                    <TextBox Header="{snuxm:StringResource Name=UIXamlPagesSettingsPageLabelProfileEndpoint}" Text="{Binding Settings.ModelProviderProfiles.CurrentItem.Endpoint, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <PasswordBox
                                        snuxc:PasswordBoxExtensions.Password="{Binding Settings.ModelProviderProfiles.CurrentItem.ApiKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        Description="{snuxm:StringResource Name=UIXamlPagesSettingsPageDescriptionProfileApiKey}"
                                        Header="{snuxm:StringResource Name=UIXamlPagesSettingsPageLabelProfileApiKey}"
                                        PasswordChar="&#x2022;"
                                        PasswordRevealMode="Peek" />

                                    <StackPanel Spacing="3">
                                        <cwc:SettingsCard Description="{snuxm:StringResource Name=UIXamlPagesSettingsPageDescriptionModelListDocumentationLink}" Header="{snuxm:StringResource Name=UIXamlPagesSettingsPageLabelModelListDocumentationLink}">
                                            <TextBox Text="{Binding Settings.ModelProviderProfiles.CurrentItem.ModelListDocumentationLink, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        </cwc:SettingsCard>
                                        <cwc:SettingsCard Header="{snuxm:StringResource Name=UIXamlPagesSettingsPageLabelModelListActions}">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <Button
                                                    Grid.Column="1"
                                                    VerticalAlignment="Top"
                                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                                    Command="{Binding RefreshModelsCommand}">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <FontIcon FontSize="16" Glyph="&#xE72C;" />
                                                        <TextBlock Text="{snuxm:StringResource Name=UIXamlPagesSettingsPageLabelFetchModels}" />
                                                    </StackPanel>
                                                </Button>
                                                <Button
                                                    Grid.Column="2"
                                                    VerticalAlignment="Top"
                                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                                    Command="{Binding AddModelCommand}">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <FontIcon FontSize="16" Glyph="&#xE710;" />
                                                        <TextBlock Text="{snuxm:StringResource Name=UIXamlPagesSettingsPageLabelAddModel}" />
                                                    </StackPanel>
                                                </Button>
                                                <Button
                                                    Grid.Column="3"
                                                    VerticalAlignment="Top"
                                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                                    Command="{Binding DeleteModelCommand}">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <FontIcon FontSize="16" Glyph="&#xE74D;" />
                                                        <TextBlock Text="{snuxm:StringResource Name=UIXamlPagesSettingsPageLabelDeleteModel}" />
                                                    </StackPanel>
                                                </Button>
                                                <Button
                                                    Grid.Column="4"
                                                    VerticalAlignment="Top"
                                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                                    Command="{Binding ClearModelsCommand}">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <FontIcon FontSize="16" Glyph="&#xE894;" />
                                                        <TextBlock Text="{snuxm:StringResource Name=UIXamlPagesSettingsPageLabelClearModels}" />
                                                    </StackPanel>
                                                </Button>
                                            </StackPanel>
                                        </cwc:SettingsCard>
                                        <InfoBar
                                            Title="{Binding ModelListStatusTitle.Value}"
                                            IsClosable="False"
                                            IsOpen="{Binding IsModelListStatusOpen, Mode=TwoWay}"
                                            Message="{Binding ModelListStatusMessage.Value}"
                                            Severity="{Binding ModelListInfoBarSeverity}"
                                            Visibility="{Binding IsModelListStatusOpen, Mode=OneWay}" />
                                        <cwc:SettingsCard Header="{snuxm:StringResource Name=UIXamlPagesSettingsPageLabelSelectedModel}">
                                            <ComboBox
                                                MinWidth="240"
                                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                                DisplayMemberPath="DisplayName">
                                                <mxi:Interaction.Behaviors>
                                                    <snuxb:ComboBoxBindingWorkaroundBehavior ItemsSource="{Binding Settings.ModelProviderProfiles.CurrentItem.ModelProfiles, Mode=OneWay}" SelectedItem="{Binding Settings.ModelProviderProfiles.CurrentItem.ModelProfiles.CurrentItem, Mode=TwoWay}" />
                                                </mxi:Interaction.Behaviors>
                                            </ComboBox>
                                        </cwc:SettingsCard>
                                        <cwc:SettingsCard Header="{snuxm:StringResource Name=UIXamlPagesSettingsPageLabelProfileModelId}">
                                            <TextBox Text="{Binding Settings.ModelProviderProfiles.CurrentItem.ModelProfiles.CurrentItem.ModelId, Mode=TwoWay}" />
                                        </cwc:SettingsCard>
                                        <cwc:SettingsCard Header="{snuxm:StringResource Name=UIXamlPagesSettingsPageLabelModelName}">
                                            <TextBox Text="{Binding Settings.ModelProviderProfiles.CurrentItem.ModelProfiles.CurrentItem.Name, Mode=TwoWay}" />
                                        </cwc:SettingsCard>
                                    </StackPanel>

                                </StackPanel>
                                <StackPanel
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Spacing="8"
                                    Visibility="{Binding Settings.ModelProviderProfiles.CurrentItem, Converter={StaticResource ModelProviderProfileEmptyStateVisibilityConverter}}">
                                    <FontIcon
                                        HorizontalAlignment="Center"
                                        FontSize="24"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        Glyph="&#xE70F;" />
                                    <TextBlock
                                        MaxWidth="320"
                                        HorizontalAlignment="Center"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        Text="{Binding ModelProviderProfileEmptyStateText.Value}"
                                        TextAlignment="Center"
                                        TextWrapping="WrapWholeWords" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
