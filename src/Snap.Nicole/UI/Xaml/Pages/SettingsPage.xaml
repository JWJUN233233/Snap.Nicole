<Page
    x:Class="Snap.Nicole.UI.Xaml.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:snux="using:Snap.Nicole.UI.Xaml"
    xmlns:snuxm="using:Snap.Nicole.UI.Xaml.Markup"
    xmlns:snv="using:Snap.Nicole.ViewModels"
    d:DataContext="{d:DesignInstance snv:SettingsViewModel}"
    mc:Ignorable="d">

    <ScrollViewer Padding="24">
        <StackPanel Spacing="8">
            <TextBlock Style="{StaticResource TitleTextBlockStyle}" Text="{snuxm:StringResource Name=UIXamlWindowsMainWindowNavigationViewItemSettingsContent}" />

            <TextBlock Text="{snuxm:StringResource Name=UIXamlPagesSettingsPageLabelLanguage}" />
            <ComboBox
                DisplayMemberPath="Label"
                ItemsSource="{Binding Languages}"
                SelectedValue="{Binding Settings.Language, Mode=TwoWay}"
                SelectedValuePath="Value" />

            <TextBlock
                Margin="0,16,0,0"
                Style="{StaticResource SubtitleTextBlockStyle}"
                Text="{snuxm:StringResource Name=UIXamlPagesSettingsPageLabelModelProfiles}" />

            <ListView
                Height="150"
                AllowDrop="True"
                CanReorderItems="True"
                DisplayMemberPath="Name"
                ItemsSource="{Binding Settings.ModelProfiles}"
                SelectedItem="{Binding Settings.ModelProfiles.CurrentItem, Mode=TwoWay}" />

            <TextBlock Text="{snuxm:StringResource Name=UIXamlPagesSettingsPageLabelProfileName}" />
            <TextBox Text="{Binding Settings.ModelProfiles.CurrentItem.Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

            <TextBlock Text="{snuxm:StringResource Name=UIXamlPagesSettingsPageLabelProfileEndpoint}" />
            <TextBox Text="{Binding Settings.ModelProfiles.CurrentItem.Endpoint, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

            <TextBlock Text="{snuxm:StringResource Name=UIXamlPagesSettingsPageLabelProfileApiKey}" />
            <TextBox Text="{Binding Settings.ModelProfiles.CurrentItem.ApiKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

            <TextBlock Text="{snuxm:StringResource Name=UIXamlPagesSettingsPageLabelProfileModelId}" />
            <TextBox Text="{Binding Settings.ModelProfiles.CurrentItem.ModelId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

            <StackPanel
                Margin="0,8,0,0"
                Orientation="Horizontal"
                Spacing="8">
                <Button Command="{Binding AddProfileCommand}" Content="{snuxm:StringResource Name=UIXamlPagesSettingsPageLabelAddProfile}" />
                <Button Command="{Binding DeleteProfileCommand}" Content="{snuxm:StringResource Name=UIXamlPagesSettingsPageLabelDeleteProfile}" />
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>
