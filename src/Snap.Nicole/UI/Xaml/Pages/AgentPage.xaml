<Page
    x:Class="Snap.Nicole.UI.Xaml.Pages.AgentPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:cwc="using:CommunityToolkit.WinUI.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:mxi="using:Microsoft.Xaml.Interactivity"
    xmlns:snuxb="using:Snap.Nicole.UI.Xaml.Behaviors"
    xmlns:snuxcc="using:Snap.Nicole.UI.Xaml.Controls.ChatElements"
    xmlns:snuxm="using:Snap.Nicole.UI.Xaml.Markup"
    xmlns:snv="using:Snap.Nicole.ViewModels.Agent"
    d:DataContext="{d:DesignInstance snv:AgentViewModel}"
    mc:Ignorable="d">

    <Page.Resources>
        <cwc:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </Page.Resources>

    <mxi:Interaction.Behaviors>
        <snuxb:DisposeDataContextOnUnloadedBehavior />
    </mxi:Interaction.Behaviors>

    <Grid ColumnSpacing="0">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border
            Grid.Column="0"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Button
                    Grid.Row="0"
                    Margin="8"
                    HorizontalAlignment="Stretch"
                    Command="{x:Bind ViewModel.CreateConversationCommand}"
                    ToolTipService.ToolTip="{snuxm:StringResource Name=UIXamlPagesAgentPageLabelNewConversation}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon FontSize="16" Glyph="&#xE710;" />
                        <TextBlock Text="{snuxm:StringResource Name=UIXamlPagesAgentPageLabelNewConversation}" />
                    </StackPanel>
                </Button>

                <ListView
                    Grid.Row="1"
                    ItemContainerTransitions="{ThemeResource ListViewLikeThemeTransitions}"
                    ItemsSource="{x:Bind ViewModel.Conversations, Mode=OneWay}"
                    SelectedItem="{Binding Conversations.CurrentItem, Mode=TwoWay}"
                    SelectionMode="Single">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid
                                MinHeight="68"
                                Padding="12,8"
                                Background="Transparent"
                                RowSpacing="4">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Grid.ContextFlyout>
                                    <MenuFlyout>
                                        <MenuFlyoutItem Command="{Binding DeleteConversationCommand}" Text="{snuxm:StringResource Name=UIXamlPagesAgentPageLabelDeleteConversation}">
                                            <MenuFlyoutItem.Icon>
                                                <FontIcon Glyph="&#xE74D;" />
                                            </MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>
                                    </MenuFlyout>
                                </Grid.ContextFlyout>

                                <TextBlock
                                    Grid.Row="0"
                                    FontWeight="SemiBold"
                                    Text="{Binding TitleDisplay.Value}"
                                    TextTrimming="CharacterEllipsis" />

                                <StackPanel
                                    Grid.Row="1"
                                    Orientation="Horizontal"
                                    Spacing="8">
                                    <TextBlock
                                        Opacity="0.7"
                                        Style="{ThemeResource CaptionTextBlockStyle}"
                                        Text="{Binding Messages.Count}" />
                                </StackPanel>

                                <TextBlock
                                    Grid.Row="2"
                                    Opacity="0.7"
                                    Style="{ThemeResource CaptionTextBlockStyle}"
                                    Text="{Binding UpdatedAtDisplay}" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border
                Grid.Row="0"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="0,0,0,1">
                <CommandBar DefaultLabelPosition="Right">
                    <CommandBar.Content>
                        <Grid Margin="13,8,0,0" ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <ComboBox Grid.Column="0" DisplayMemberPath="Name">
                                <mxi:Interaction.Behaviors>
                                    <snuxb:SelectorSelectedItemBindingWorkaroundBehavior ItemsSource="{Binding Settings.ModelProviderProfiles}" SelectedItem="{Binding Conversations.CurrentItem.ModelProviderProfile, Mode=TwoWay}" />
                                </mxi:Interaction.Behaviors>
                            </ComboBox>

                            <ComboBox Grid.Column="1" DisplayMemberPath="DisplayName">
                                <mxi:Interaction.Behaviors>
                                    <snuxb:SelectorSelectedItemBindingWorkaroundBehavior ItemsSource="{Binding Conversations.CurrentItem.ModelProviderProfile.ModelProfiles, Mode=OneWay}" SelectedItem="{Binding Conversations.CurrentItem.ModelProfile, Mode=TwoWay}" />
                                </mxi:Interaction.Behaviors>
                            </ComboBox>
                        </Grid>
                    </CommandBar.Content>

                    <AppBarButton Label="{snuxm:StringResource Name=UIXamlPagesAgentPageLabelContext}" ToolTipService.ToolTip="{snuxm:StringResource Name=UIXamlPagesAgentPageLabelContext}">
                        <AppBarButton.Icon>
                            <FontIcon Glyph="&#xE8A5;" />
                        </AppBarButton.Icon>
                        <AppBarButton.Flyout>
                            <Flyout>
                                <Flyout.FlyoutPresenterStyle>
                                    <Style BasedOn="{StaticResource DefaultFlyoutPresenterStyle}" TargetType="FlyoutPresenter">
                                        <Setter Property="MinWidth" Value="360" />
                                    </Style>
                                </Flyout.FlyoutPresenterStyle>
                                <Grid
                                    ColumnSpacing="12"
                                    DataContext="{x:Bind ViewModel}"
                                    RowSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <StackPanel Grid.Row="0" Grid.Column="0">
                                        <TextBlock
                                            Opacity="0.7"
                                            Style="{ThemeResource CaptionTextBlockStyle}"
                                            Text="{snuxm:StringResource Name=UIXamlPagesAgentPageLabelMessages}" />
                                        <TextBlock Text="{Binding Conversations.CurrentItem.ConversationStatistics.MessageCount}" />
                                    </StackPanel>
                                    <StackPanel Grid.Row="0" Grid.Column="1">
                                        <TextBlock
                                            Opacity="0.7"
                                            Style="{ThemeResource CaptionTextBlockStyle}"
                                            Text="{snuxm:StringResource Name=UIXamlPagesAgentPageLabelContents}" />
                                        <TextBlock Text="{Binding Conversations.CurrentItem.ConversationStatistics.ContentCount}" />
                                    </StackPanel>
                                    <StackPanel Grid.Row="1" Grid.Column="0">
                                        <TextBlock
                                            Opacity="0.7"
                                            Style="{ThemeResource CaptionTextBlockStyle}"
                                            Text="{snuxm:StringResource Name=UIXamlPagesAgentPageLabelTextContents}" />
                                        <TextBlock Text="{Binding Conversations.CurrentItem.ConversationStatistics.TextContentCount}" />
                                    </StackPanel>
                                    <StackPanel Grid.Row="1" Grid.Column="1">
                                        <TextBlock
                                            Opacity="0.7"
                                            Style="{ThemeResource CaptionTextBlockStyle}"
                                            Text="{snuxm:StringResource Name=UIXamlPagesAgentPageLabelReasoningContents}" />
                                        <TextBlock Text="{Binding Conversations.CurrentItem.ConversationStatistics.ReasoningContentCount}" />
                                    </StackPanel>
                                    <StackPanel Grid.Row="2" Grid.Column="0">
                                        <TextBlock
                                            Opacity="0.7"
                                            Style="{ThemeResource CaptionTextBlockStyle}"
                                            Text="{snuxm:StringResource Name=UIXamlPagesAgentPageLabelToolCalls}" />
                                        <TextBlock Text="{Binding Conversations.CurrentItem.ConversationStatistics.ToolCallCount}" />
                                    </StackPanel>
                                    <StackPanel Grid.Row="2" Grid.Column="1">
                                        <TextBlock
                                            Opacity="0.7"
                                            Style="{ThemeResource CaptionTextBlockStyle}"
                                            Text="{snuxm:StringResource Name=UIXamlPagesAgentPageLabelToolResults}" />
                                        <TextBlock Text="{Binding Conversations.CurrentItem.ConversationStatistics.ToolResultCount}" />
                                    </StackPanel>
                                    <StackPanel Grid.Row="3" Grid.Column="0">
                                        <TextBlock
                                            Opacity="0.7"
                                            Style="{ThemeResource CaptionTextBlockStyle}"
                                            Text="{snuxm:StringResource Name=UIXamlPagesAgentPageLabelTotalTokens}" />
                                        <TextBlock Text="{Binding Conversations.CurrentItem.ConversationStatistics.TotalTokenCount}" />
                                    </StackPanel>
                                    <StackPanel Grid.Row="3" Grid.Column="1">
                                        <TextBlock
                                            Opacity="0.7"
                                            Style="{ThemeResource CaptionTextBlockStyle}"
                                            Text="{snuxm:StringResource Name=UIXamlPagesAgentPageLabelInputTokens}" />
                                        <TextBlock Text="{Binding Conversations.CurrentItem.ConversationStatistics.InputTokenCount}" />
                                    </StackPanel>
                                    <StackPanel Grid.Row="4" Grid.Column="0">
                                        <TextBlock
                                            Opacity="0.7"
                                            Style="{ThemeResource CaptionTextBlockStyle}"
                                            Text="{snuxm:StringResource Name=UIXamlPagesAgentPageLabelOutputTokens}" />
                                        <TextBlock Text="{Binding Conversations.CurrentItem.ConversationStatistics.OutputTokenCount}" />
                                    </StackPanel>
                                    <StackPanel Grid.Row="4" Grid.Column="1">
                                        <TextBlock
                                            Opacity="0.7"
                                            Style="{ThemeResource CaptionTextBlockStyle}"
                                            Text="{snuxm:StringResource Name=UIXamlPagesAgentPageLabelReasoningTokens}" />
                                        <TextBlock Text="{Binding Conversations.CurrentItem.ConversationStatistics.ReasoningTokenCount}" />
                                    </StackPanel>
                                    <StackPanel Grid.Row="5" Grid.Column="0">
                                        <TextBlock
                                            Opacity="0.7"
                                            Style="{ThemeResource CaptionTextBlockStyle}"
                                            Text="{snuxm:StringResource Name=UIXamlPagesAgentPageLabelCachedInputTokens}" />
                                        <TextBlock Text="{Binding Conversations.CurrentItem.ConversationStatistics.CachedInputTokenCount}" />
                                    </StackPanel>
                                </Grid>
                            </Flyout>
                        </AppBarButton.Flyout>
                    </AppBarButton>
                </CommandBar>
            </Border>

            <ScrollViewer Grid.Row="1">
                <ItemsControl
                    Margin="16,16,16,8"
                    ItemContainerTransitions="{ThemeResource AddDeleteThemeTransitions}"
                    ItemsSource="{Binding Conversations.CurrentItem.Messages}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <snuxcc:ChatMessageView Margin="0,0,0,8" Message="{Binding}" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <ItemsStackPanel ItemsUpdatingScrollMode="KeepLastItemInView" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>
            </ScrollViewer>

            <Grid
                Grid.Row="2"
                Padding="16"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="0,1,0,0"
                ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBox
                    Grid.Column="0"
                    MaxHeight="120"
                    AcceptsReturn="True"
                    IsSpellCheckEnabled="False"
                    PlaceholderText="{snuxm:StringResource Name=UIXamlPagesAgentPageLabelPlaceholder}"
                    Text="{Binding Conversations.CurrentItem.InputText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                    <mxi:Interaction.Behaviors>
                        <snuxb:SubmitOnEnterTextBoxBehavior Command="{Binding Conversations.CurrentItem.SendMessageCommand}" />
                    </mxi:Interaction.Behaviors>
                </TextBox>

                <Button
                    Grid.Column="1"
                    MinWidth="144"
                    VerticalAlignment="Bottom"
                    Command="{Binding Conversations.CurrentItem.SendMessageCommand}"
                    Content="{snuxm:StringResource Name=UIXamlPagesAgentPageLabelSend}"
                    Visibility="{Binding Conversations.CurrentItem.CanStopGeneration, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=True}" />

                <Button
                    Grid.Column="1"
                    MinWidth="144"
                    VerticalAlignment="Bottom"
                    Command="{Binding Conversations.CurrentItem.StopGenerationCommand}"
                    Content="{snuxm:StringResource Name=UIXamlPagesAgentPageLabelStopGeneration}"
                    Visibility="{Binding Conversations.CurrentItem.CanStopGeneration, Converter={StaticResource BoolToVisibilityConverter}}" />
            </Grid>
        </Grid>
    </Grid>
</Page>
