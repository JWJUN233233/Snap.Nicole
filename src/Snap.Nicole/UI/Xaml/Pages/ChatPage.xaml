<Page
    x:Class="Snap.Nicole.UI.Xaml.Pages.ChatPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:mxi="using:Microsoft.Xaml.Interactivity"
    xmlns:snuxb="using:Snap.Nicole.UI.Xaml.Behaviors"
    xmlns:snuxcc="using:Snap.Nicole.UI.Xaml.Controls.ChatElements"
    xmlns:snuxm="using:Snap.Nicole.UI.Xaml.Markup"
    xmlns:snv="using:Snap.Nicole.ViewModels"
    d:DataContext="{d:DesignInstance snv:ChatViewModel}"
    mc:Ignorable="d">

    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid
            Grid.Row="0"
            Margin="0,0,0,12"
            ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>

            <ComboBox
                Grid.Column="0"
                MinWidth="240"
                DisplayMemberPath="Name"
                Header="{snuxm:StringResource Name=UIXamlPagesChatPageLabelModelProviderProfile}"
                ItemsSource="{Binding Settings.ModelProviderProfiles}"
                SelectedItem="{Binding Settings.ModelProviderProfiles.CurrentItem, Mode=TwoWay}" />

            <ComboBox
                Grid.Column="1"
                MinWidth="240"
                DisplayMemberPath="DisplayName"
                Header="{snuxm:StringResource Name=UIXamlPagesChatPageLabelModelProfile}"
                ItemsSource="{Binding Settings.ModelProviderProfiles.CurrentItem.ModelProfiles}"
                SelectedItem="{Binding Settings.ModelProviderProfiles.CurrentItem.ModelProfiles.CurrentItem, Mode=TwoWay}" />
        </Grid>

        <ScrollViewer x:Name="ChatScrollViewer" Grid.Row="1">
            <ItemsControl ItemContainerTransitions="{ThemeResource AddDeleteThemeTransitions}" ItemsSource="{x:Bind ViewModel.Messages, Mode=OneWay}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <snuxcc:ChatMessageView Margin="0,0,0,8" Message="{Binding}" />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <ItemsStackPanel ItemsUpdatingScrollMode="KeepLastItemInView" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>
        </ScrollViewer>

        <Grid
            Grid.Row="2"
            Margin="0,12,0,0"
            ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBox
                x:Name="InputBox"
                Grid.Column="0"
                MaxHeight="120"
                AcceptsReturn="True"
                IsSpellCheckEnabled="False"
                PlaceholderText="{snuxm:StringResource Name=UIXamlPagesChatPageLabelPlaceholder}"
                Text="{x:Bind ViewModel.InputText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                <mxi:Interaction.Behaviors>
                    <snuxb:SubmitOnEnterTextBoxBehavior Command="{x:Bind ViewModel.SendMessageCommand}" />
                </mxi:Interaction.Behaviors>
            </TextBox>

            <Button
                x:Name="SendButton"
                Grid.Column="1"
                VerticalAlignment="Bottom"
                Command="{x:Bind ViewModel.SendMessageCommand}"
                Content="{snuxm:StringResource Name=UIXamlPagesChatPageLabelSend}" />

            <Button
                x:Name="ClearButton"
                Grid.Column="2"
                VerticalAlignment="Bottom"
                Command="{x:Bind ViewModel.ClearChatCommand}"
                Content="{snuxm:StringResource Name=UIXamlPagesChatPageLabelClear}" />
        </Grid>
    </Grid>
</Page>
